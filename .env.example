# ============================================================
# Variables de entorno - Sistema de Alerta Temprana de Huaicos
# Copia este archivo a .env.local y completa los valores.
# .env.local NUNCA se commitea (ver .gitignore).
# ============================================================

# --- Base de datos: Postgres de Supabase ---
# Panel Supabase -> Settings -> Database -> "Connection string".
# Usa la de Connection pooling (modo Transaction, puerto 6543) para serverless.
DATABASE_URL=postgresql://usuario:password@host:6543/postgres

# --- Supabase: Storage para media (fotos/voz ciudadanas, audio TTS) ---
# Panel Supabase -> Settings -> API.
# SUPABASE_URL = "Project URL".
# SUPABASE_SERVICE_ROLE_KEY = key "service_role" (secret). Acceso total: NUNCA del lado cliente.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM primario: Mistral AI ---
# Registrate en console.mistral.ai (tiene tier gratis para desarrollar).
MISTRAL_API_KEY=

# --- LLM fallback: OpenRouter (flexibilidad de modelos) ---
OPENROUTER_API_KEY=

# --- Telegram: bot creado con @BotFather ---
# En Telegram escribe a @BotFather -> /newbot -> te entrega el token. Es secreto.
TELEGRAM_BOT_TOKEN=
# Te la inventas tu; valida que los webhooks vienen de Telegram. Generala con:  openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# --- MiniMax: TTS (voz del copiloto) ---
# Sintetiza en voz la respuesta del copiloto vía /api/tts (modelo T2A v2).
# Si no se configura, el copiloto usa el TTS nativo del navegador como respaldo.
MINIMAX_API_KEY=
# Group ID de tu cuenta MiniMax. Opcional: solo se envía si está presente.
MINIMAX_GROUP_ID=
# Opcionales (tienen valor por defecto; descoméntalos solo para cambiarlos):
# MINIMAX_MODEL=speech-02-hd
# MINIMAX_VOICE_ID=Spanish_SereneWoman
# MINIMAX_API_BASE=https://api.minimax.io

# --- NASA Earthdata: descarga de GPM IMERG ---
# Crea un token en https://urs.earthdata.nasa.gov/
EARTHDATA_TOKEN=

# --- Seguridad de los cron jobs de Vercel ---
# Te la inventas tu (no viene de ningun servicio). Generala con:  openssl rand -hex 32
# El mismo valor va aqui y en las Environment Variables de Vercel.
CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
